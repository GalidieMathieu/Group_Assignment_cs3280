<Window x:Class="Group_Assignment.Main.wndMain"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Weber Accounting Invoice System"
        Height="720"
        Width="1120"
        Loaded="Window_Loaded">
    <DockPanel Margin="18">
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_Invoice">
                <MenuItem Header="_New Invoice" Click="mnuNewInvoice_Click" />
                <MenuItem Header="_Edit Current Invoice" Click="mnuEditInvoice_Click" />
            </MenuItem>
            <MenuItem Header="_Tools">
                <MenuItem Header="_Search Invoices" Click="mnuSearchInvoices_Click" />
                <MenuItem x:Name="mnuManageItems" Header="_Manage Items" Click="mnuManageItems_Click" />
            </MenuItem>
        </Menu>

        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <TextBlock x:Name="txtDatabaseStatus" Text="Database status: checking..." />
            </StatusBarItem>
        </StatusBar>

        <Grid Margin="0,16,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <GroupBox Grid.Row="0" Header="Invoice Summary" Margin="0,0,0,16">
                <Grid Margin="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200" />
                        <ColumnDefinition Width="24" />
                        <ColumnDefinition Width="200" />
                        <ColumnDefinition Width="24" />
                        <ColumnDefinition Width="200" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Invoice Number" Style="{StaticResource FormLabelTextStyle}" />
                    <TextBlock Grid.Row="0" Grid.Column="2" Text="Invoice Date" Style="{StaticResource FormLabelTextStyle}" />
                    <TextBlock Grid.Row="0" Grid.Column="4" Text="Total Charge" Style="{StaticResource FormLabelTextStyle}" />

                    <TextBox Grid.Row="1" Grid.Column="0" x:Name="txtInvoiceNumber" Style="{StaticResource ReadOnlyTextBoxStyle}" Text="TBD" />
                    <DatePicker Grid.Row="1" Grid.Column="2" x:Name="dpInvoiceDate" />
                    <TextBox Grid.Row="1" Grid.Column="4" x:Name="txtTotalCharge" Style="{StaticResource ReadOnlyTextBoxStyle}" Text="$0.00" />

                    <StackPanel Grid.Row="1" Grid.Column="5" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="btnNewInvoice" Content="New Invoice" Click="btnNewInvoice_Click" Margin="0,0,12,0" />
                        <Button x:Name="btnEditInvoice" Content="Edit Invoice" Click="btnEditInvoice_Click" Margin="0,0,12,0" />
                        <Button x:Name="btnSaveInvoice" Content="Save Invoice" Click="btnSaveInvoice_Click" />
                    </StackPanel>
                </Grid>
            </GroupBox>

            <GroupBox Grid.Row="1" Header="Add Item" Margin="0,0,0,16">
                <Grid Margin="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="24" />
                        <ColumnDefinition Width="180" />
                        <ColumnDefinition Width="24" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Item" Style="{StaticResource FormLabelTextStyle}" />
                    <TextBlock Grid.Row="0" Grid.Column="2" Text="Default Cost" Style="{StaticResource FormLabelTextStyle}" />

                    <ComboBox Grid.Row="1"
                              Grid.Column="0"
                              x:Name="cmbItems"
                              DisplayMemberPath="DisplayText"
                              SelectionChanged="cmbItems_SelectionChanged" />

                    <TextBox Grid.Row="1"
                             Grid.Column="2"
                             x:Name="txtItemCost"
                             Style="{StaticResource ReadOnlyTextBoxStyle}"
                             Text="$0.00" />

                    <Button Grid.Row="1"
                            Grid.Column="4"
                            x:Name="btnAddItem"
                            Content="Add Item"
                            Click="btnAddItem_Click" />
                </Grid>
            </GroupBox>

            <GroupBox Grid.Row="2" Header="Invoice Items">
                <DockPanel Margin="16">
                    <Button DockPanel.Dock="Top"
                            x:Name="btnRemoveSelectedItem"
                            Content="Remove Selected Item"
                            Click="btnRemoveSelectedItem_Click"
                            HorizontalAlignment="Right"
                            Margin="0,0,0,12" />

                    <DataGrid x:Name="dgInvoiceItems"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              SelectionChanged="dgInvoiceItems_SelectionChanged">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Line #" Binding="{Binding LineNumber}" Width="90" />
                            <DataGridTextColumn Header="Item Code" Binding="{Binding ItemCode}" Width="140" />
                            <DataGridTextColumn Header="Description" Binding="{Binding ItemDescription}" Width="*" />
                            <DataGridTextColumn Header="Cost" Binding="{Binding ItemCost, StringFormat={}{0:C}}" Width="140" />
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </GroupBox>
        </Grid>
    </DockPanel>
</Window>
