<Window x:Class="Group_Assignment.Search.wndSearch"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Search Invoices"
        Height="620"
        Width="980"
        Loaded="Window_Loaded">
    <DockPanel Margin="18">
        <StackPanel DockPanel.Dock="Bottom"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,16,0,0">
            <Button Content="Clear Selection" Click="btnClearSelection_Click" Margin="0,0,12,0" />
            <Button Content="Select Invoice" Click="btnSelectInvoice_Click" Margin="0,0,12,0" />
            <Button Content="Close" Click="btnClose_Click" />
        </StackPanel>

        <TextBlock DockPanel.Dock="Bottom"
                   x:Name="txtSearchStatus"
                   Margin="0,12,0,0"
                   Text="Search screen ready."
                   Style="{StaticResource StatusTextStyle}" />

        <GroupBox DockPanel.Dock="Top" Header="Search Filters" Margin="0,0,0,16">
            <Grid Margin="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="24" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="24" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Invoice Number" Style="{StaticResource FormLabelTextStyle}" />
                <TextBlock Grid.Row="0" Grid.Column="2" Text="Invoice Date" Style="{StaticResource FormLabelTextStyle}" />
                <TextBlock Grid.Row="0" Grid.Column="4" Text="Total Charge" Style="{StaticResource FormLabelTextStyle}" />

                <ComboBox Grid.Row="1"
                          Grid.Column="0"
                          x:Name="cmbInvoiceNumber"
                          SelectionChanged="SearchFilter_Changed" />

                <DatePicker Grid.Row="1"
                            Grid.Column="2"
                            x:Name="dpInvoiceDate"
                            SelectedDateChanged="SearchFilter_Changed" />

                <ComboBox Grid.Row="1"
                          Grid.Column="4"
                          x:Name="cmbTotalCharge"
                          ItemStringFormat="{}{0:C}"
                          SelectionChanged="SearchFilter_Changed" />
            </Grid>
        </GroupBox>

        <GroupBox Header="Invoices">
            <DataGrid x:Name="dgInvoices"
                      Margin="16"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      IsReadOnly="True"
                      SelectionMode="Single">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Invoice Number" Binding="{Binding InvoiceNumber}" Width="160" />
                    <DataGridTextColumn Header="Invoice Date" Binding="{Binding InvoiceDate, StringFormat={}{0:d}}" Width="180" />
                    <DataGridTextColumn Header="Total Charge" Binding="{Binding TotalCharge, StringFormat={}{0:C}}" Width="180" />
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>
    </DockPanel>
</Window>
